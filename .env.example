# =============================================================================
# SHOPLINE Sync Service - Environment Configuration
# =============================================================================
# NOTE: All variables can be provided as either environment variables or
# secrets (e.g., from Google Cloud Secret Manager). The application will
# use whichever is provided. Secrets take precedence if both are defined.
#
# Secret Manager names (project shopify-473015) already created:
#   SHOPLINE_API_KEY, SHOPLINE_API_SECRET, SHOPLINE_WEBHOOK_SECRET,
#   SHOPLINE_OAUTH_REDIRECT_URL
# =============================================================================

# Environment Configuration
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=DEBUG

# Database Configuration
# Same shared PostgreSQL DB (chekoutai) as every other backend service.
# search_path is pinned to the shopline_sync schema in the DSN.
DB_DSN=postgresql://user:password@localhost:5432/chekoutai?options=-c%20search_path=shopline_sync

# API Key for Service-to-Service Authentication
# Required for all endpoints except health checks and SHOPLINE webhooks.
# Generate using: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
API_KEY=your_generated_api_key_here

# SHOPLINE Open Platform API Configuration
SHOPLINE_API_KEY=your_shopline_client_id
SHOPLINE_API_SECRET=your_shopline_client_secret
# Used to verify webhook HMAC. Often equals the app secret — confirm at first webhook test.
SHOPLINE_WEBHOOK_SECRET=your_shopline_webhook_secret
# ⚠️ Confirm the exact API version string against developer.shopline.com (date-based, e.g. v20251201)
SHOPLINE_API_VERSION=v20251201
SHOPLINE_SCOPES=read_products,read_orders

# Application Configuration
APP_HOST=0.0.0.0
APP_PORT=8000

# OAuth Redirect URL — ⚠️ NO query params allowed by SHOPLINE.
# Production value (reserved Cloud Run URL):
#   https://shopline-sync-393304610205.us-central1.run.app/api/oauth/callback
SHOPLINE_OAUTH_REDIRECT_URL=http://localhost:8000/api/oauth/callback

# Public base URL of this service (for webhook subscription registration)
APP_URL=http://localhost:8000

# Where /api/oauth/callback redirects the browser after a successful connect.
# The chekoutai builder reads ?status=connected&merchant_id=...&shop_handle=...
# If unset, the callback returns JSON instead of redirecting (handy for local dev).
# Deployed value (production-forward; set in deploy.sh): https://app.chekout.ai/ai-agent
SHOPLINE_FRONTEND_RETURN_URL=

# Security - Token Encryption (encrypts access_token + refresh_token at rest)
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your_generated_encryption_key_here

# Scheduler Configuration (Section 3 — token refresh + reconciliation)
ENABLE_SCHEDULER=true
RECONCILIATION_HOUR=2
RECONCILIATION_MINUTE=0

# Google Cloud Platform Configuration (required for embeddings)
GCP_PROJECT_ID=shopify-473015
GCP_REGION=us-central1
ENABLE_EMBEDDINGS=true
# For local development, set path to service account key
GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account-key.json
